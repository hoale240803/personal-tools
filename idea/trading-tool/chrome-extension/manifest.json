{
  "manifest_version": 3,
  "name": "Bitcoin Signal Tracker",
  "version": "1.0.0",
  "description": "Real-time Bitcoin Long/Short signal detection from TurtleTrading",
  
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "tabs"
  ],
  
  "host_permissions": [
    "https://signals.turtletrading.vn/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://signals.turtletrading.vn/chart/*"],
      "js": ["utils.js", "content-script.js"],
      "run_at": "document_end"
    }
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Bitcoin Signal Tracker"
  }
}
